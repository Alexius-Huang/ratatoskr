    "build:server": "~/.bun/bin/bun build ./server/prod.ts --compile --outfile ./src-tauri/binaries/ratatoskr-server-aarch64-apple-darwin && codesign --remove-signature ./src-tauri/binaries/ratatoskr-server-aarch64-apple-darwin 2>/dev/null; codesign --force --sign - ./src-tauri/binaries/ratatoskr-server-aarch64-apple-darwin",
    "build:mcp": "~/.bun/bin/bun build ./server/mcp.ts --compile --outfile ./src-tauri/binaries/ratatoskr-mcp-aarch64-apple-darwin && codesign --remove-signature ./src-tauri/binaries/ratatoskr-mcp-aarch64-apple-darwin 2>/dev/null; codesign --force --sign - ./src-tauri/binaries/ratatoskr-mcp-aarch64-apple-darwin",
    "mcp:dev": "~/.bun/bin/bun server/mcp.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "pnpm build && pnpm build:server && tauri build"
  },
  "dependencies": {
    "@atlaskit/pragmatic-drag-and-drop": "^1.8.0",
